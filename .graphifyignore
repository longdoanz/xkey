# Default seeded by graphify SessionStart hook — edit/commit freely.
# graphify also honors .gitignore, so deps/build dirs listed there are excluded.

# Deps / build output (redundant-safe)
vendor/
node_modules/
.venv/
dist/
build/
out/
target/

# Committed generated code (.gitignore usually does NOT cover these)
*_gen.go
*.pb.go
*.pb.gw.go
*_pb2.py
*.g.dart
*.freezed.dart
**/gen/
# entgo (Go): ignore generated output, keep hand-written schema
ent/*
!ent/schema/

# Mocks / fixtures
mock_*.go
*_mock.go
mocks/
__mocks__/

# Docs — .md headings dominate keyword matches; keep the graph code-only
docs/
*.md
